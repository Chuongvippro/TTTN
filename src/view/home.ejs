<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' — ' : '' %>Pawmie Pet Shop</title>

  <!-- Bootstrap 5 -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Font Awesome -->
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@400;500;600;700;800&family=Nunito:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <!-- Main CSS -->
  <link rel="stylesheet" href="/css/home.css">
</head>
<body>

  <%- include('partials/navbar') %>

  <main>

<!-- ═══════════════════════════════════════════
     HERO SECTION — Single static banner
════════════════════════════════════════════ -->
<section class="hero-section" style="position:relative;overflow:hidden;">
  <div style="position:relative;min-height:680px;display:flex;align-items:center;">
    <!-- Ảnh nền full bleed -->
    <img
      src="https://images.unsplash.com/photo-1587300003388-59208cc962cb?w=1600&q=85"
      alt="Pawmie hero"
      style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center;z-index:0;"
    >
    <!-- Overlay gradient -->
    <div style="position:absolute;inset:0;background:linear-gradient(90deg,rgba(0,0,0,0.68) 0%,rgba(0,0,0,0.32) 55%,rgba(0,0,0,0.05) 100%);z-index:1;"></div>
    <!-- Nội dung -->
    <div class="container-fluid px-5" style="position:relative;z-index:2;width:100%;">
      <div style="max-width:600px;">
        <div class="hero-badge" style="background:rgba(255,255,255,0.18);border-color:rgba(255,255,255,0.4);color:#fff;margin-bottom:20px;">
          <span>🎀</span> Bộ sưu tập mới nhất
        </div>
        <h1 class="hero-title" style="color:#fff;text-shadow:0 2px 16px rgba(0,0,0,0.35);">
          Yêu thương <span style="color:#FFE08A;">thú cưng</span><br>từng khoảnh khắc
        </h1>
        <p class="hero-desc" style="color:rgba(255,255,255,0.92);">
          Hàng ngàn phụ kiện cao cấp cho bé cún & bé mèo —<br>
          chất lượng đảm bảo, giao hàng nhanh toàn quốc.
        </p>
        <div class="hero-cta">
          <a href="/products" class="btn-primary-custom">
            <i class="fas fa-shopping-bag"></i> Mua sắm ngay
          </a>
          <a href="/products?filter=new" class="btn-outline-custom" style="background:rgba(255,255,255,0.18);border-color:rgba(255,255,255,0.5);color:#fff;">
            <i class="fas fa-star"></i> Hàng mới về
          </a>
        </div>
      </div>
    </div>
  </div>
</section>



<!-- ═══════════════════════════════════════════
     MUA SẮM THEO LOẠI THÚ CƯNG
════════════════════════════════════════════ -->
<section class="section-pad" style="background:#fff;">
  <div class="container">
    <div class="section-header">
      <div class="section-tag"><i class="fas fa-paw me-1"></i> Thú cưng</div>
      <h2 class="section-title">Mua sắm theo <span>loại thú cưng</span></h2>
      <p class="section-desc">Chọn bé nhà bạn để xem sản phẩm phù hợp nhất</p>
    </div>

    <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:20px;margin-top:8px;">

      <!-- Chó -->
      <a href="/products?pet_type=dog" style="text-decoration:none;">
        <div class="pet-type-card" style="
          background:linear-gradient(135deg,#FFF8E8,#FFF0C8);
          border:2px solid #FFE08A; border-radius:20px;
          padding:32px 16px; text-align:center;
          transition:all 0.25s; cursor:pointer;
        " onmouseover="this.style.transform='translateY(-6px)';this.style.boxShadow='0 12px 32px rgba(255,176,0,0.2)'"
           onmouseout="this.style.transform='';this.style.boxShadow=''">
          <div style="font-size:3.2rem;margin-bottom:12px;filter:drop-shadow(0 4px 8px rgba(0,0,0,0.1));">🐕</div>
          <div style="font-family:'Baloo 2',cursive;font-size:1.15rem;font-weight:800;color:#92400e;margin-bottom:4px;">Chó</div>
          <div style="font-size:0.82rem;color:#b45309;font-weight:600;">Mọi giống & mọi size</div>
        </div>
      </a>

      <!-- Mèo -->
      <a href="/products?pet_type=cat" style="text-decoration:none;">
        <div class="pet-type-card" style="
          background:linear-gradient(135deg,#F0F9FF,#E0F2FE);
          border:2px solid #BAE6FD; border-radius:20px;
          padding:32px 16px; text-align:center;
          transition:all 0.25s; cursor:pointer;
        " onmouseover="this.style.transform='translateY(-6px)';this.style.boxShadow='0 12px 32px rgba(14,165,233,0.2)'"
           onmouseout="this.style.transform='';this.style.boxShadow=''">
          <div style="font-size:3.2rem;margin-bottom:12px;filter:drop-shadow(0 4px 8px rgba(0,0,0,0.1));">🐈</div>
          <div style="font-family:'Baloo 2',cursive;font-size:1.15rem;font-weight:800;color:#0c4a6e;margin-bottom:4px;">Mèo</div>
          <div style="font-size:0.82rem;color:#0369a1;font-weight:600;">Mọi giống & mọi size</div>
        </div>
      </a>

      <!-- Thỏ -->
      <a href="/products?pet_type=rabbit" style="text-decoration:none;">
        <div class="pet-type-card" style="
          background:linear-gradient(135deg,#FDF4FF,#FAE8FF);
          border:2px solid #E9D5FF; border-radius:20px;
          padding:32px 16px; text-align:center;
          transition:all 0.25s; cursor:pointer;
        " onmouseover="this.style.transform='translateY(-6px)';this.style.boxShadow='0 12px 32px rgba(168,85,247,0.2)'"
           onmouseout="this.style.transform='';this.style.boxShadow=''">
          <div style="font-size:3.2rem;margin-bottom:12px;filter:drop-shadow(0 4px 8px rgba(0,0,0,0.1));">🐇</div>
          <div style="font-family:'Baloo 2',cursive;font-size:1.15rem;font-weight:800;color:#581c87;margin-bottom:4px;">Thỏ</div>
          <div style="font-size:0.82rem;color:#7c3aed;font-weight:600;">Xinh xắn & dễ thương</div>
        </div>
      </a>

      <!-- Chuột Hamster -->
      <a href="/products?pet_type=hamster" style="text-decoration:none;">
        <div class="pet-type-card" style="
          background:linear-gradient(135deg,#FFF1F2,#FFE4E6);
          border:2px solid #FECDD3; border-radius:20px;
          padding:32px 16px; text-align:center;
          transition:all 0.25s; cursor:pointer;
        " onmouseover="this.style.transform='translateY(-6px)';this.style.boxShadow='0 12px 32px rgba(244,63,94,0.2)'"
           onmouseout="this.style.transform='';this.style.boxShadow=''">
          <div style="font-size:3.2rem;margin-bottom:12px;filter:drop-shadow(0 4px 8px rgba(0,0,0,0.1));">🐹</div>
          <div style="font-family:'Baloo 2',cursive;font-size:1.15rem;font-weight:800;color:#881337;margin-bottom:4px;">Hamster</div>
          <div style="font-size:0.82rem;color:#be123c;font-weight:600;">Nhỏ nhắn & tinh nghịch</div>
        </div>
      </a>

      <!-- Khác -->
      <a href="/products?pet_type=other" style="text-decoration:none;">
        <div class="pet-type-card" style="
          background:linear-gradient(135deg,#F0FDF4,#DCFCE7);
          border:2px solid #BBF7D0; border-radius:20px;
          padding:32px 16px; text-align:center;
          transition:all 0.25s; cursor:pointer;
        " onmouseover="this.style.transform='translateY(-6px)';this.style.boxShadow='0 12px 32px rgba(34,197,94,0.2)'"
           onmouseout="this.style.transform='';this.style.boxShadow=''">
          <div style="font-size:3.2rem;margin-bottom:12px;filter:drop-shadow(0 4px 8px rgba(0,0,0,0.1));">🦎</div>
          <div style="font-family:'Baloo 2',cursive;font-size:1.15rem;font-weight:800;color:#14532d;margin-bottom:4px;">Khác</div>
          <div style="font-size:0.82rem;color:#15803d;font-weight:600;">Chim, bò sát & nhiều hơn</div>
        </div>
      </a>

    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════
     MUA SẮM THEO DANH MỤC SẢN PHẨM
════════════════════════════════════════════ -->
   <!-- PHẦN DANH MỤC SẢN PHẨM (DÙNG ĐỂ RENDER ĐỘNG) -->
<section class="section-pad" style="background:#f9fafb;">
  <div class="container">
    <div class="section-header">
      <div class="section-tag"><i class="fas fa-th-large me-1"></i> Danh mục</div>
      <h2 class="section-title">Mua sắm theo <span>danh mục</span></h2>
      <p class="section-desc">Tìm đúng sản phẩm bạn cần trong nháy mắt</p>
    </div>

    <div id="categoryGrid" class="category-grid-container" style="display:grid; grid-template-columns:repeat(auto-fill, minmax(200px, 1fr)); gap:20px; margin-top:20px;">
        <p class="text-center">Đang tải danh mục... 🐾</p>
    </div>
  </div>
</section>


<section class="section-pad featured-section">
  <div class="container">
    <div class="section-header">
      <div class="section-tag"><i class="fas fa-fire me-1"></i> Bán chạy nhất</div>
      <h2 class="section-title">Sản phẩm <span>nổi bật</span></h2>
      <p class="section-desc">Được yêu thích nhất bởi hàng ngàn pet parent</p>
    </div>

    <div style="display:flex;gap:8px;justify-content:center;flex-wrap:wrap;margin-bottom:36px;">
      <button class="filter-tab active" data-filter="all" style="
        padding:8px 20px; border-radius:99px; border:2px solid var(--border);
        background:var(--primary); color:#fff; font-weight:700; font-size:0.85rem;
        cursor:pointer; transition:all 0.25s; font-family:var(--font-body);
      ">Tất cả</button>
      <button class="filter-tab" data-filter="dog" style="
        padding:8px 20px; border-radius:99px; border:2px solid var(--border);
        background:var(--white); color:var(--text); font-weight:700; font-size:0.85rem;
        cursor:pointer; transition:all 0.25s; font-family:var(--font-body);
      ">🐶 Chó</button>
      <button class="filter-tab" data-filter="cat" style="
        padding:8px 20px; border-radius:99px; border:2px solid var(--border);
        background:var(--white); color:var(--text); font-weight:700; font-size:0.85rem;
        cursor:pointer; transition:all 0.25s; font-family:var(--font-body);
      ">🐱 Mèo</button>
      <button class="filter-tab" data-filter="sale" style="
        padding:8px 20px; border-radius:99px; border:2px solid var(--border);
        background:var(--white); color:var(--text); font-weight:700; font-size:0.85rem;
        cursor:pointer; transition:all 0.25s; font-family:var(--font-body);
      ">🔥 Đang giảm</button>
    </div>

    <div class="products-grid" id="featuredGrid">
      <% if (typeof featuredProducts !== 'undefined' && featuredProducts.length > 0) { %>
      <% featuredProducts.forEach(product => { %>
      <%- include('partials/product-card', { product }) %>
      <% }) %>
      <% } else { %>
      <% const demoProducts = [
          { id:1, name:'Vòng cổ da mềm cho chó', price:89000, originalPrice:120000, image:'https://images.unsplash.com/photo-1576201836106-db1758fd1c97?w=400&q=80', category:'Phụ kiện chó', rating:4.8, reviewCount:124, badge:'Bán chạy', categorySlug:'dog' },
          { id:2, name:'Nhà mèo lắp ghép cao cấp', price:450000, originalPrice:null, image:'https://images.unsplash.com/photo-1545249390-6bdfa286032f?w=400&q=80', category:'Nhà & chuồng', rating:4.6, reviewCount:87, badge:'Mới', categorySlug:'cat' },
          { id:3, name:'Đồ chơi cần câu cho mèo', price:65000, originalPrice:90000, image:'https://images.unsplash.com/photo-1592194996308-7b43878e84a6?w=400&q=80', category:'Đồ chơi mèo', rating:4.9, reviewCount:203, badge:'Sale', categorySlug:'cat' },
          { id:4, name:'Áo hoodie cho chó nhỏ', price:185000, originalPrice:220000, image:'https://images.unsplash.com/photo-1587300003388-59208cc962cb?w=400&q=80', category:'Quần áo chó', rating:4.7, reviewCount:56, badge:null, categorySlug:'dog' },
          { id:5, name:'Bát ăn silicon chống trượt', price:95000, originalPrice:null, image:'https://images.unsplash.com/photo-1601758123927-196f78426b69?w=400&q=80', category:'Dụng cụ ăn uống', rating:4.5, reviewCount:142, badge:'Bán chạy', categorySlug:'dog' },
          { id:6, name:'Cát vệ sinh mèo thơm', price:125000, originalPrice:150000, image:'https://images.unsplash.com/photo-1574158622682-e40e69881006?w=400&q=80', category:'Vệ sinh mèo', rating:4.8, reviewCount:318, badge:'Sale', categorySlug:'cat' },
          { id:7, name:'Dây dắt chó tự cuộn 5m', price:220000, originalPrice:null, image:'https://images.unsplash.com/photo-1546421845-6471bdcf3edf?w=400&q=80', category:'Phụ kiện chó', rating:4.4, reviewCount:79, badge:'Mới', categorySlug:'dog' },
          { id:8, name:'Đệm nằm siêu mềm cho mèo', price:310000, originalPrice:380000, image:'https://images.unsplash.com/photo-1513245543132-31f507417b26?w=400&q=80', category:'Nhà & chuồng', rating:4.9, reviewCount:167, badge:null, categorySlug:'cat' }
        ] %>
      <% demoProducts.forEach(product => { %>
      <div class="product-card" data-category="<%= product.categorySlug %>" data-sale="<%= product.originalPrice ? 'true' : 'false' %>">
        <div class="product-img-wrap">
          <% if (product.badge) { %>
          <span class="product-badge <%= product.badge === 'Sale' ? 'sale' : product.badge === 'Mới' ? 'new' : '' %>">
            <%= product.badge %>
          </span>
          <% } %>
          <button class="product-wish" data-id="<%= product.id %>" onclick="toggleWishlist(this, this.dataset.id)" aria-label="Yêu thích">
            <i class="far fa-heart"></i>
          </button>
          <a href="/products/<%= product.id %>">
            <img src="<%= product.image %>" alt="<%= product.name %>" loading="lazy">
          </a>
        </div>
        <div class="product-body">
          <div class="product-category"><%= product.category %></div>
          <a href="/products/<%= product.id %>" class="product-name"><%= product.name %></a>
          <div class="product-rating">
            <span class="stars">
              <% for(let i = 1; i <= 5; i++) { %>
              <%= i <= Math.round(product.rating) ? '★' : '☆' %>
              <% } %>
            </span>
            <span class="rating-count">(<%= product.reviewCount %>)</span>
          </div>
          <div class="product-price-row">
            <span class="product-price"><%= product.price.toLocaleString('vi-VN') %>₫</span>
            <% if (product.originalPrice) { %>
            <span class="product-price-old"><%= product.originalPrice.toLocaleString('vi-VN') %>₫</span>
            <% } %>
          </div>
          <button class="btn-add-cart" data-id="<%= product.id %>" onclick="addToCart(this.dataset.id, this)">
            <i class="fas fa-shopping-bag"></i> Thêm vào giỏ
          </button>
        </div>
      </div>
      <% }) %>
      <% } %>
    </div>

    <div class="text-center mt-5">
      <a href="/products" class="btn-outline-custom" style="display:inline-flex;">
        Xem tất cả sản phẩm <i class="fas fa-arrow-right ms-2"></i>
      </a>
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════
     SECTION: SẢN PHẨM ĐANG GIẢM GIÁ
════════════════════════════════════════════ -->
<section class="section-pad" style="background:#fff8f5;">
  <div class="container">
    <div class="section-header">
      <div class="section-tag"><i class="fas fa-tag me-1"></i> Giảm giá</div>
      <h2 class="section-title">Sản phẩm <span>đang giảm giá</span> 🔥</h2>
      <p class="section-desc">Ưu đãi có hạn — số lượng có hạn, đặt hàng ngay!</p>
    </div>

    <!-- Wrapper slider -->
    <div style="position:relative;">
      <!-- Nút trái -->
      <button id="salePrev" onclick="slideSale(-1)" style="
        position:absolute; left:-20px; top:50%; transform:translateY(-50%);
        z-index:10; width:44px; height:44px; border-radius:50%;
        background:#fff; border:2px solid #fde8e0;
        color:#E85D28; font-size:1rem; cursor:pointer;
        display:flex; align-items:center; justify-content:center;
        box-shadow:0 4px 14px rgba(232,93,40,0.15);
        transition:all 0.25s;
      " onmouseover="this.style.background='#E85D28';this.style.color='#fff'"
         onmouseout="this.style.background='#fff';this.style.color='#E85D28'">
        <i class="fas fa-chevron-left"></i>
      </button>

      <!-- Track -->
      <div style="overflow:hidden;">
        <div id="saleTrack" style="
            display:grid;
            grid-template-columns: repeat(6, 1fr); 
            gap:20px;
            transition: transform 0.4s cubic-bezier(0.25,0.46,0.45,0.94);
        ">

          <% if (typeof saleProducts !== 'undefined' && saleProducts.length > 0) { %>
            <% saleProducts.forEach(product => { %>
              <%- include('partials/product-card', { product }) %>
            <% }) %>
          <% } else { %>
            <% const saleDemo = [
              { id:101, name:'Vòng cổ da mềm cho chó', price:89000, originalPrice:130000, image:'https://images.unsplash.com/photo-1576201836106-db1758fd1c97?w=400&q=80', category:'Phụ kiện chó', rating:4.8, reviewCount:124, badge:'Sale', categorySlug:'dog' },
              { id:102, name:'Cát vệ sinh mèo thơm 5kg', price:75000, originalPrice:110000, image:'https://images.unsplash.com/photo-1574158622682-e40e69881006?w=400&q=80', category:'Vệ sinh mèo', rating:4.7, reviewCount:89, badge:'Sale', categorySlug:'cat' },
              { id:103, name:'Đệm nằm siêu mềm oval', price:195000, originalPrice:280000, image:'https://images.unsplash.com/photo-1513245543132-31f507417b26?w=400&q=80', category:'Nhà & Chuồng', rating:4.9, reviewCount:211, badge:'Sale', categorySlug:'dog' },
              { id:104, name:'Đồ chơi cần câu mèo LED', price:45000, originalPrice:70000, image:'https://images.unsplash.com/photo-1592194996308-7b43878e84a6?w=400&q=80', category:'Đồ chơi mèo', rating:4.8, reviewCount:167, badge:'Sale', categorySlug:'cat' },
              { id:105, name:'Áo hoodie chó nhỏ', price:140000, originalPrice:200000, image:'https://images.unsplash.com/photo-1587300003388-59208cc962cb?w=400&q=80', category:'Quần áo', rating:4.6, reviewCount:53, badge:'Sale', categorySlug:'dog' },
              { id:106, name:'Bát ăn silicon chống trượt', price:65000, originalPrice:95000, image:'https://images.unsplash.com/photo-1601758123927-196f78426b69?w=400&q=80', category:'Dụng cụ ăn uống', rating:4.5, reviewCount:142, badge:'Sale', categorySlug:'dog' },
              { id:107, name:'Lược chải lông tự làm sạch', price:88000, originalPrice:125000, image:'https://images.unsplash.com/photo-1546421845-6471bdcf3edf?w=400&q=80', category:'Chăm sóc', rating:4.7, reviewCount:76, badge:'Sale', categorySlug:'care' },
              { id:108, name:'Nhà cát mèo có nắp đậy', price:320000, originalPrice:450000, image:'https://images.unsplash.com/photo-1545249390-6bdfa286032f?w=400&q=80', category:'Vệ sinh mèo', rating:4.8, reviewCount:98, badge:'Sale', categorySlug:'cat' }
            ] %>
            <% saleDemo.forEach(product => { %>
            <div class="product-card sale-slide-item">
              <div class="product-img-wrap">
                <span class="product-badge sale"><%= product.badge %></span>
                <%# ✅ Dùng data-id thay vì EJS trong onclick để tránh linter warning %>
                <button class="product-wish" data-id="<%= product.id %>" onclick="toggleWishlist(this, this.dataset.id)" aria-label="Yêu thích">
                  <i class="far fa-heart"></i>
                </button>
                <a href="/products/<%= product.id %>">
                  <img src="<%= product.image %>" alt="<%= product.name %>" loading="lazy">
                </a>
              </div>
              <div class="product-body">
                <div class="product-category"><%= product.category %></div>
                <a href="/products/<%= product.id %>" class="product-name"><%= product.name %></a>
                <div class="product-rating">
                  <span class="stars">
                    <% for(let i=1;i<=5;i++){ %><%= i<=Math.round(product.rating)?'★':'☆' %><% } %>
                  </span>
                  <span class="rating-count">(<%= product.reviewCount %>)</span>
                </div>
                <div class="product-price-row">
                  <span class="product-price"><%= product.price.toLocaleString('vi-VN') %>₫</span>
                  <span class="product-price-old"><%= product.originalPrice.toLocaleString('vi-VN') %>₫</span>
                  <span style="background:#fee2e2;color:#dc3545;font-size:0.72rem;font-weight:800;padding:2px 7px;border-radius:99px;">
                    -<%= Math.round((1 - product.price/product.originalPrice)*100) %>%
                  </span>
                </div>
                <button class="btn-add-cart" data-id="<%= product.id %>" onclick="addToCart(this.dataset.id, this)">
                  <i class="fas fa-shopping-bag"></i> Thêm vào giỏ
                </button>
              </div>
            </div>
            <% }) %>
          <% } %>

        </div>
      </div>

      <!-- Nút phải -->
      <button id="saleNext" onclick="slideSale(1)" style="
        position:absolute; right:-20px; top:50%; transform:translateY(-50%);
        z-index:10; width:44px; height:44px; border-radius:50%;
        background:#fff; border:2px solid #fde8e0;
        color:#E85D28; font-size:1rem; cursor:pointer;
        display:flex; align-items:center; justify-content:center;
        box-shadow:0 4px 14px rgba(232,93,40,0.15);
        transition:all 0.25s;
      " onmouseover="this.style.background='#E85D28';this.style.color='#fff'"
         onmouseout="this.style.background='#fff';this.style.color='#E85D28'">
        <i class="fas fa-chevron-right"></i>
      </button>
    </div>

    <!-- Dots indicator -->
    <div id="saleDots" style="display:flex;justify-content:center;gap:8px;margin-top:24px;"></div>

    <!-- Nút xem thêm -->
    <div class="text-center mt-4">
      <a href="/products?sale=1" class="btn-primary-custom" style="display:inline-flex;">
        Xem tất cả sản phẩm giảm giá <i class="fas fa-arrow-right ms-2"></i>
      </a>
    </div>
  </div>
</section>

<script>
(function() {
  const track    = document.getElementById('saleTrack');
  const dotsWrap = document.getElementById('saleDots');
  if (!track) return;

  const items      = track.children;
  const perPage = window.innerWidth < 768 ? 2 : window.innerWidth < 1024 ? 3 : 4; 
  const total      = items.length;
  const maxPage    = Math.max(0, total - perPage);
  let   current    = 0;

  // Tạo dots
  const numDots = Math.ceil(total / perPage);
  for (let i = 0; i < numDots; i++) {
    const dot = document.createElement('button');
    dot.style.cssText = `width:8px;height:8px;border-radius:50%;border:none;
      background:${i===0?'#E85D28':'#f0f0f0'};cursor:pointer;padding:0;transition:all 0.25s;`;
    dot.addEventListener('click', () => goTo(i * perPage));
    dotsWrap.appendChild(dot);
  }

  function updateDots() {
    Array.from(dotsWrap.children).forEach((d, i) => {
      d.style.background = i === Math.round(current / perPage) ? '#E85D28' : '#f0f0f0';
      d.style.width      = i === Math.round(current / perPage) ? '20px' : '8px';
      d.style.borderRadius = '99px';
    });
  }

  function goTo(idx) {
    current = Math.max(0, Math.min(idx, maxPage));
    // Tính % dịch chuyển dựa trên grid columns
    const pct = (current / perPage) * 100;
    track.style.transform = `translateX(-${pct}%)`;
    track.style.gridTemplateColumns = `repeat(${total}, calc(${100/perPage}% - ${(perPage-1)*20/perPage}px))`;
    updateDots();

    document.getElementById('salePrev').style.opacity = current === 0 ? '0.4' : '1';
    document.getElementById('saleNext').style.opacity = current >= maxPage ? '0.4' : '1';
  }

  // Init grid
  track.style.gridTemplateColumns = `repeat(${total}, calc(${100/perPage}% - ${(perPage-1)*20/perPage}px))`;
  updateDots();

  window.slideSale = function(dir) {
    goTo(current + dir);
  };
})();
</script>


