<!DOCTYPE html>
<html lang="vi">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Đơn hàng của tôi — Pawmie Pet Shop</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
  <link
    href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@400;700;800&family=Nunito:wght@400;600;700;800&display=swap"
    rel="stylesheet">
  <link rel="stylesheet" href="/css/home.css">
  <style>
    body {
      background: #f9fafb;
      font-family: 'Nunito', sans-serif;
    }

    main {
      padding: 40px 0 80px;
    }

    .page-title {
      font-family: 'Baloo 2', cursive;
      font-weight: 800;
      font-size: 2rem;
      color: #222;
      margin-bottom: 32px;
    }

    /* ── Status badge ── */
    .status-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 5px 14px;
      border-radius: 99px;
      font-size: 0.82rem;
      font-weight: 800;
    }

    .status-pending {
      background: #fef9c3;
      color: #854d0e;
    }

    .status-confirmed {
      background: #dbeafe;
      color: #1e40af;
    }

    .status-shipping {
      background: #e0f2fe;
      color: #0369a1;
    }

    .status-delivered {
      background: #dcfce7;
      color: #166534;
    }

    .status-cancelled {
      background: #fee2e2;
      color: #991b1b;
    }

    /* ── Order card ── */
    .order-card {
      background: #fff;
      border-radius: 20px;
      border: 1.5px solid #f0f0f0;
      margin-bottom: 20px;
      overflow: hidden;
      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.03);
      transition: box-shadow 0.2s;
    }

    .order-card:hover {
      box-shadow: 0 6px 24px rgba(232, 93, 40, 0.08);
    }

    .order-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 18px 24px;
      cursor: pointer;
      border-bottom: 1.5px solid #f5f5f5;
      flex-wrap: wrap;
      gap: 12px;
    }

    .order-id {
      font-family: 'Baloo 2', cursive;
      font-weight: 800;
      font-size: 1.05rem;
      color: #222;
    }

    .order-meta {
      font-size: 0.85rem;
      color: #888;
      font-weight: 600;
      margin-top: 2px;
    }

    .order-total {
      font-size: 1.15rem;
      font-weight: 800;
      color: #E85D28;
    }

    .toggle-icon {
      color: #aaa;
      font-size: 0.9rem;
      transition: transform 0.25s;
    }

    .toggle-icon.open {
      transform: rotate(180deg);
    }

    /* ── Order body ── */
    .order-body {
      display: none;
      padding: 20px 24px;
    }

    .order-body.show {
      display: block;
    }

    /* Timeline trạng thái */
    .status-timeline {
      display: flex;
      align-items: flex-start;
      gap: 0;
      margin-bottom: 24px;
      overflow-x: auto;
      padding-bottom: 8px;
    }

    .timeline-step {
      flex: 1;
      min-width: 80px;
      display: flex;
      flex-direction: column;
      align-items: center;
      position: relative;
    }

    .timeline-step::before {
      content: '';
      position: absolute;
      top: 16px;
      left: 50%;
      right: -50%;
      height: 2px;
      background: #e8e8e8;
      z-index: 0;
    }

    .timeline-step:last-child::before {
      display: none;
    }

    .timeline-dot {
      width: 34px;
      height: 34px;
      border-radius: 50%;
      background: #f0f0f0;
      border: 2px solid #e8e8e8;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.9rem;
      color: #aaa;
      z-index: 1;
      transition: all 0.3s;
    }

    .timeline-step.done .timeline-dot {
      background: #E85D28;
      border-color: #E85D28;
      color: #fff;
      box-shadow: 0 4px 12px rgba(232, 93, 40, 0.3);
    }

    .timeline-step.done::before {
      background: #E85D28;
    }

    .timeline-step.active .timeline-dot {
      background: #fff;
      border-color: #E85D28;
      color: #E85D28;
      box-shadow: 0 0 0 4px rgba(232, 93, 40, 0.15);
      animation: pulse 1.5s infinite;
    }

    .timeline-step.cancelled .timeline-dot {
      background: #fee2e2;
      border-color: #fca5a5;
      color: #dc3545;
    }

    @keyframes pulse {

      0%,
      100% {
        box-shadow: 0 0 0 4px rgba(232, 93, 40, 0.15);
      }

      50% {
        box-shadow: 0 0 0 8px rgba(232, 93, 40, 0.05);
      }
    }

    .timeline-label {
      font-size: 0.75rem;
      font-weight: 700;
      color: #888;
      margin-top: 6px;
      text-align: center;
      line-height: 1.3;
    }

    .timeline-step.done .timeline-label,
    .timeline-step.active .timeline-label {
      color: #E85D28;
    }

    .timeline-step.cancelled .timeline-label {
      color: #dc3545;
    }

    /* Sản phẩm */
    .order-item {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 12px 0;
      border-bottom: 1px solid #f5f5f5;
    }

    .order-item:last-child {
      border-bottom: none;
    }

    .order-item img {
      width: 60px;
      height: 60px;
      object-fit: cover;
      border-radius: 10px;
      border: 1px solid #eee;
      flex-shrink: 0;
    }

    .order-item-name {
      font-weight: 700;
      font-size: 0.92rem;
      color: #333;
    }

    .order-item-sub {
      font-size: 0.82rem;
      color: #888;
      margin-top: 2px;
    }

    .order-item-price {
      font-weight: 800;
      color: #E85D28;
      margin-left: auto;
      white-space: nowrap;
    }

    /* Thông tin giao hàng */
    .delivery-info {
      background: #fafafa;
      border-radius: 12px;
      padding: 16px 20px;
      margin-top: 16px;
      font-size: 0.9rem;
    }

    .delivery-row {
      display: flex;
      gap: 8px;
      padding: 5px 0;
      align-items: flex-start;
    }

    .delivery-label {
      color: #888;
      font-weight: 700;
      min-width: 100px;
    }

    .delivery-value {
      color: #333;
      font-weight: 600;
    }

    /* Payment badge */
    .pay-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: #f0f9ff;
      color: #0369a1;
      padding: 4px 12px;
      border-radius: 99px;
      font-size: 0.8rem;
      font-weight: 800;
    }

    /* Empty state */
    .empty-state {
      text-align: center;
      padding: 80px 20px;
      background: #fff;
      border-radius: 20px;
      border: 1.5px dashed #e8e8e8;
    }

    .empty-icon {
      font-size: 4rem;
      margin-bottom: 16px;
    }

    .empty-title {
      font-family: 'Baloo 2', cursive;
      font-size: 1.5rem;
      font-weight: 700;
      color: #333;
    }

    .empty-desc {
      color: #888;
      margin-top: 8px;
      font-size: 0.95rem;
    }
  </style>
</head>

<body>

  <%- include('partials/navbar') %>

    <main>
      <div class="container">

        <div class="d-flex align-items-center justify-content-between mb-4" style="flex-wrap:wrap;gap:12px;">
          <h1 class="page-title mb-0">
            <i class="fas fa-box-open me-2" style="color:#E85D28;"></i> Đơn hàng của tôi
          </h1>
          <a href="/products" class="btn-outline-custom" style="display:inline-flex;font-size:0.9rem;">
            <i class="fas fa-shopping-bag me-2"></i> Tiếp tục mua sắm
          </a>
        </div>

        <% if (!orders || orders.length===0) { %>
          <!-- Chưa có đơn nào -->
          <div class="empty-state">
            <div class="empty-icon">📦</div>
            <div class="empty-title">Chưa có đơn hàng nào</div>
            <p class="empty-desc">Hãy chọn sản phẩm yêu thích và đặt hàng ngay!</p>
            <a href="/products" class="btn-primary-custom" style="display:inline-flex;margin-top:20px;">
              <i class="fas fa-paw me-2"></i> Khám phá sản phẩm
            </a>
          </div>

          <% } else { %>

            <% orders.forEach((order, idx)=> {
              // Map trạng thái
              const statusMap = {
              pending: { label: 'Chờ xác nhận', cls: 'status-pending', icon: 'fas fa-clock' },
              confirmed: { label: 'Đã xác nhận', cls: 'status-confirmed', icon: 'fas fa-check-circle' },
              shipping: { label: 'Đang giao', cls: 'status-shipping', icon: 'fas fa-truck' },
              delivered: { label: 'Đã giao', cls: 'status-delivered', icon: 'fas fa-box-open' },
              cancelled: { label: 'Đã hủy', cls: 'status-cancelled', icon: 'fas fa-times-circle' },
              };
              const st = statusMap[order.status] || statusMap.pending;

              // Timeline steps
              const steps = [
              { key: 'pending', icon: 'fas fa-receipt', label: 'Đặt hàng' },
              { key: 'confirmed', icon: 'fas fa-check', label: 'Xác nhận' },
              { key: 'shipping', icon: 'fas fa-truck', label: 'Đang giao' },
              { key: 'delivered', icon: 'fas fa-home', label: 'Đã nhận' },
              ];
              const stepOrder = ['pending','confirmed','shipping','delivered'];
              const currentIdx = stepOrder.indexOf(order.status);
              %>

              <div class="order-card">

                <!-- Header (click để expand) -->
                <div class="order-header" data-idx="<%= idx %>" data-order-id="<%= order.id %>"
                  onclick="toggleOrder(this.dataset.idx)">
                  <div>
                    <div class="order-id">#<%= order.id %>
                    </div>
                    <div class="order-meta">
                      <i class="fas fa-calendar-alt me-1"></i>
                      <%= new Date(order.created_at).toLocaleDateString('vi-VN', { day:'2-digit', month:'2-digit',
                        year:'numeric', hour:'2-digit', minute:'2-digit' }) %>
                        &nbsp;·&nbsp; <%= order.items.length %> sản phẩm
                    </div>
                  </div>

                  <div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap;">
                    <span class="status-badge <%= st.cls %>">
                      <i class="<%= st.icon %>"></i>
                      <%= st.label %>
                    </span>
                    <span class="order-total">
                      <%= Number(order.total_price).toLocaleString('vi-VN') %>₫
                    </span>
                    <i class="fas fa-chevron-down toggle-icon" id="icon-<%= idx %>"></i>
                  </div>
                </div>

                <!-- Body (collapsible) -->
                <div class="order-body" id="body-<%= idx %>">

                  <% if (order.status !=='cancelled' ) { %>
                    <!-- Timeline -->
                    <div class="status-timeline">
                      <% steps.forEach((step, sIdx)=> {
                        let cls = '';
                        if (currentIdx > sIdx) cls = 'done';
                        else if (currentIdx === sIdx) cls = 'active';
                        %>
                        <div class="timeline-step <%= cls %>">
                          <div class="timeline-dot">
                            <i class="<%= step.icon %>"></i>
                          </div>
                          <div class="timeline-label">
                            <%= step.label %>
                          </div>
                        </div>
                        <% }) %>
                    </div>
                    <% } else { %>
                      <div style="text-align:center;padding:16px 0;color:#dc3545;font-weight:700;font-size:0.95rem;">
                        <i class="fas fa-times-circle me-2"></i> Đơn hàng đã bị hủy
                      </div>
                      <% } %>

                        <!-- Danh sách sản phẩm -->
                        <div style="margin-bottom:8px;font-weight:800;color:#333;font-size:0.95rem;">
                          <i class="fas fa-shopping-bag me-2" style="color:#E85D28;"></i>Sản phẩm
                        </div>
                        <% order.items.forEach(item=> { %>
                          <div class="order-item">
                            <img src="/<%= item.img || 'uploads/default.jpg' %>" alt="<%= item.name %>"
                              onerror="this.src='/uploads/default.jpg'">
                            <div style="flex:1;min-width:0;">
                              <div class="order-item-name">
                                <%= item.name %>
                              </div>
                              <div class="order-item-sub">
                                <%= Number(item.price).toLocaleString('vi-VN') %>₫ × <%= item.quantity %>
                              </div>
                            </div>
                            <div class="order-item-price">
                              <%= (Number(item.price) * item.quantity).toLocaleString('vi-VN') %>₫
                            </div>
                          </div>
                          <% }) %>

                            <!-- Tổng + thông tin giao hàng -->
                            <div class="delivery-info">
                              <div style="font-weight:800;color:#333;margin-bottom:10px;font-size:0.92rem;">
                                <i class="fas fa-map-marker-alt me-2" style="color:#E85D28;"></i>Thông tin giao hàng
                              </div>
                              <div class="delivery-row">
                                <span class="delivery-label">Người nhận</span>
                                <span class="delivery-value">
                                  <%= order.full_name %>
                                </span>
                              </div>
                              <div class="delivery-row">
                                <span class="delivery-label">Điện thoại</span>
                                <span class="delivery-value">
                                  <%= order.phone %>
                                </span>
                              </div>
                              <div class="delivery-row">
                                <span class="delivery-label">Địa chỉ</span>
                                <span class="delivery-value">
                                  <%= order.address %>
                                </span>
                              </div>
                              <% if (order.note) { %>
                                <div class="delivery-row">
                                  <span class="delivery-label">Ghi chú</span>
                                  <span class="delivery-value">
                                    <%= order.note %>
                                  </span>
                                </div>
                                <% } %>
                                  <div class="delivery-row">
                                    <span class="delivery-label">Thanh toán</span>
                                    <span class="pay-badge">
                                      <% if (order.payment_method==='transfer' ) { %>
                                        <i class="fas fa-university"></i> Chuyển khoản
                                        <% } else { %>
                                          <i class="fas fa-money-bill"></i> Tiền mặt (COD)
                                          <% } %>
                                    </span>
                                  </div>
                                  <div class="delivery-row"
                                    style="border-top:1px solid #eee;margin-top:10px;padding-top:10px;">
                                    <span class="delivery-label">Tổng tiền</span>
                                    <span style="font-weight:800;font-size:1.1rem;color:#E85D28;">
                                      <%= Number(order.total_price).toLocaleString('vi-VN') %>₫
                                    </span>
                                  </div>
                            </div>

                            <div class="text-end mt-3">
                              <% if (order.status==='pending' ) { %>
                                <button class="btn btn-danger btn-sm" style="border-radius: 20px; padding: 5px 20px;"
                                  onclick="cancelOrder('<%= order.id %>')">
                                  Hủy đơn hàng
                                </button>
                                <% } else { %>
                                  <button class="btn btn-secondary btn-sm"
                                    style="border-radius: 20px; padding: 5px 20px;" disabled>
                                    Hủy đơn hàng
                                  </button>
                                  <div class="small text-muted mt-1" style="font-size: 0.7rem;">
                                    * Chỉ có thể hủy khi đơn đang chờ xác nhận
                                  </div>
                                  <% } %>
                            </div>
                </div><!-- /order-body -->
              </div><!-- /order-card -->

              <% }) %>
                <% } %>

      </div>
    </main>

    <%- include('partials/footer') %>

      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
      <script src="/js/api.js"></script>
      <script src="/js/profile.js"></script>

      <script>
        function toggleOrder(idx) {
          const body = document.getElementById('body-' + idx);
          const icon = document.getElementById('icon-' + idx);
          body.classList.toggle('show');
          icon.classList.toggle('open');
        }

        //chỉ mở đơn đc click vào
        const urlParams = new URLSearchParams(window.location.search);
        const targetOrderId = urlParams.get('orderId');

        if (targetOrderId) {
          const targetHeader = document.querySelector(`.order-header[data-order-id="${targetOrderId}"]`);
          if (targetHeader) {
            const targetIdx = targetHeader.getAttribute('data-idx');
            toggleOrder(targetIdx); // Mở đúng đơn đó

            setTimeout(() => {
              targetHeader.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }, 300);
          }
        } else {
          if (document.getElementById('body-0')) {
            toggleOrder(0);
          }
        }
      </script>
</body>

</html>