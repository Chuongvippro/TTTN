<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Blog — Pawmie Pet Shop</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@400;700;800&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/home.css">
  <style>
    body { background: #f9fafb; font-family: 'Nunito', sans-serif; }

    /* ── Hero ── */
    .blog-hero {
      background: linear-gradient(135deg, #fff8f5 0%, #ffeee6 60%, #fff3f0 100%);
      padding: 60px 0 40px;
      border-bottom: 1.5px solid #fde8e0;
    }
    .blog-hero-title {
      font-family: 'Baloo 2', cursive;
      font-size: 2.6rem; font-weight: 800; color: #222;
      margin-bottom: 8px;
    }
    .blog-hero-title span { color: #E85D28; }
    .blog-hero-desc { color: #666; font-size: 1.05rem; font-weight: 600; }

    /* ── Search bar ── */
    .search-wrap {
      position: relative; max-width: 520px;
      margin: 28px auto 0;
    }
    .search-input {
      width: 100%; padding: 14px 50px 14px 20px;
      border: 2px solid #e8e8e8; border-radius: 14px;
      font-family: 'Nunito', sans-serif; font-size: 1rem;
      outline: none; transition: border-color 0.2s;
      background: #fff;
    }
    .search-input:focus { border-color: #E85D28; }
    .search-btn {
      position: absolute; right: 8px; top: 50%;
      transform: translateY(-50%);
      background: #E85D28; color: #fff;
      border: none; border-radius: 10px;
      width: 38px; height: 38px;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer; transition: background 0.2s;
    }
    .search-btn:hover { background: #d65120; }

    /* ── Layout ── */
    .blog-layout { padding: 48px 0 80px; }

    /* ── Category filter ── */
    .cat-filter {
      background: #fff; border-radius: 16px;
      padding: 20px; border: 1.5px solid #f0f0f0;
      margin-bottom: 20px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.03);
    }
    .cat-filter-title {
      font-family: 'Baloo 2', cursive;
      font-weight: 700; font-size: 1rem; color: #333;
      margin-bottom: 14px;
    }
    .cat-tag {
      display: inline-block; padding: 6px 14px;
      border-radius: 99px; border: 1.5px solid #e8e8e8;
      font-size: 0.85rem; font-weight: 700; color: #555;
      margin: 0 4px 8px 0; cursor: pointer;
      text-decoration: none; transition: all 0.2s;
    }
    .cat-tag:hover, .cat-tag.active {
      background: #E85D28; color: #fff; border-color: #E85D28;
    }
    .cat-count {
      font-size: 0.75rem; background: rgba(255,255,255,0.25);
      border-radius: 99px; padding: 1px 7px; margin-left: 4px;
    }
    .cat-tag:not(.active) .cat-count {
      background: #f0f0f0; color: #888;
    }

    /* Popular posts widget */
    .widget {
      background: #fff; border-radius: 16px;
      padding: 20px; border: 1.5px solid #f0f0f0;
      margin-bottom: 20px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.03);
    }
    .widget-title {
      font-family: 'Baloo 2', cursive;
      font-weight: 700; font-size: 1rem; color: #333;
      margin-bottom: 14px; padding-bottom: 12px;
      border-bottom: 2px dashed #f0f0f0;
    }
    .widget-item {
      display: flex; gap: 10px; align-items: flex-start;
      padding: 8px 0; border-bottom: 1px solid #f5f5f5;
      text-decoration: none;
    }
    .widget-item:last-child { border-bottom: none; }
    .widget-item img {
      width: 52px; height: 52px; object-fit: cover;
      border-radius: 8px; flex-shrink: 0;
    }
    .widget-item-title {
      font-size: 0.85rem; font-weight: 700; color: #333;
      line-height: 1.4;
    }
    .widget-item-title:hover { color: #E85D28; }
    .widget-item-meta { font-size: 0.75rem; color: #aaa; margin-top: 3px; }

    /* ── Blog card ── */
    .blog-card {
      background: #fff; border-radius: 20px;
      border: 1.5px solid #f0f0f0; overflow: hidden;
      margin-bottom: 28px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.03);
      transition: transform 0.25s, box-shadow 0.25s;
    }
    .blog-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 32px rgba(232,93,40,0.1);
    }
    .blog-card-img {
      width: 100%; height: 220px; object-fit: cover;
      transition: transform 0.4s;
    }
    .blog-card:hover .blog-card-img { transform: scale(1.04); }
    .blog-card-img-wrap { overflow: hidden; }

    .blog-card-body { padding: 20px 22px 22px; }
    .blog-card-cat {
      display: inline-block; background: #fff3ee;
      color: #E85D28; border-radius: 99px;
      padding: 3px 12px; font-size: 0.78rem;
      font-weight: 800; margin-bottom: 10px;
    }
    .blog-card-title {
      font-family: 'Baloo 2', cursive;
      font-size: 1.2rem; font-weight: 700; color: #222;
      margin-bottom: 8px; text-decoration: none; display: block;
      line-height: 1.4;
    }
    .blog-card-title:hover { color: #E85D28; }
    .blog-card-summary {
      color: #666; font-size: 0.9rem; line-height: 1.6;
      margin-bottom: 14px;
      display: -webkit-box; -webkit-line-clamp: 2;
      -webkit-box-orient: vertical; overflow: hidden;
    }
    .blog-card-meta {
      display: flex; align-items: center; gap: 14px;
      font-size: 0.8rem; color: #aaa; font-weight: 600;
    }
    .blog-card-meta i { margin-right: 4px; }

    /* ── Pagination ── */
    .page-btn {
      display: inline-flex; align-items: center; justify-content: center;
      width: 38px; height: 38px; border-radius: 10px;
      border: 1.5px solid #e8e8e8; background: #fff;
      font-weight: 700; font-size: 0.9rem; color: #555;
      text-decoration: none; transition: all 0.2s; margin: 0 3px;
    }
    .page-btn:hover, .page-btn.active {
      background: #E85D28; color: #fff; border-color: #E85D28;
    }
    .page-btn.disabled { opacity: 0.4; pointer-events: none; }

    /* ── Empty ── */
    .empty-blog {
      text-align: center; padding: 60px 20px;
      background: #fff; border-radius: 20px;
      border: 1.5px dashed #e8e8e8;
    }
  </style>
</head>
<body>

  <%- include('partials/navbar') %>

  <!-- Hero -->
  <div class="blog-hero">
    <div class="container text-center">
      <div class="blog-hero-title">🐾 Blog <span>Thú Cưng</span></div>
      <p class="blog-hero-desc">Kiến thức chăm sóc, mẹo hay và câu chuyện về thú cưng</p>

      <!-- Search -->
      <form action="/blog" method="GET">
        <% if (currentCategory) { %>
          <input type="hidden" name="category" value="<%= currentCategory %>">
        <% } %>
        <div class="search-wrap">
          <input type="text" name="search" class="search-input"
            placeholder="Tìm kiếm bài viết..."
            value="<%= search || '' %>">
          <button type="submit" class="search-btn">
            <i class="fas fa-search"></i>
          </button>
        </div>
      </form>
    </div>
  </div>

  <main class="blog-layout">
    <div class="container">
      <div class="row g-4">

        <!-- ── CỘT TRÁI: Bài viết ── -->
        <div class="col-lg-8">

          <% if (search) { %>
            <p style="color:#666;font-weight:600;margin-bottom:20px;">
              <i class="fas fa-search me-2" style="color:#E85D28;"></i>
              Kết quả tìm kiếm cho "<strong><%= search %></strong>": <%= total %> bài viết
            </p>
          <% } %>

          <% if (!posts || posts.length === 0) { %>
            <div class="empty-blog">
              <div style="font-size:3rem;margin-bottom:12px;">📝</div>
              <div style="font-family:'Baloo 2',cursive;font-size:1.4rem;font-weight:700;color:#333;">
                Chưa có bài viết nào
              </div>
              <p style="color:#888;margin-top:8px;">Hãy quay lại sau nhé!</p>
              <a href="/blog" class="btn-outline-custom" style="display:inline-flex;margin-top:16px;">
                Xem tất cả bài viết
              </a>
            </div>

          <% } else { %>
            <div class="row g-4">
              <% posts.forEach(post => { %>
              <div class="col-md-6">
                <div class="blog-card">
                  <div class="blog-card-img-wrap">
                    <img
                      class="blog-card-img"
                      src="/<%= post.thumbnail || '' %>"
                      alt="<%= post.title %>"
                      onerror="this.src='https://images.unsplash.com/photo-1587300003388-59208cc962cb?w=600&q=80'"
                    >
                  </div>
                  <div class="blog-card-body">
                    <% if (post.category_name) { %>
                      <span class="blog-card-cat"><%= post.category_name %></span>
                    <% } %>
                    <a href="/blog/<%= post.slug %>" class="blog-card-title">
                      <%= post.title %>
                    </a>
                    <% if (post.summary) { %>
                      <p class="blog-card-summary"><%= post.summary %></p>
                    <% } %>
                    <div class="blog-card-meta">
                      <span><i class="fas fa-eye"></i><%= post.views || 0 %></span>
                      <span><i class="fas fa-comment"></i><%= post.comment_count || 0 %></span>
                      <span><i class="fas fa-calendar-alt"></i>
                        <%= new Date(post.created_at).toLocaleDateString('vi-VN') %>
                      </span>
                    </div>
                  </div>
                </div>
              </div>
              <% }) %>
            </div>

            <!-- Pagination -->
            <% if (totalPages > 1) { %>
            <div class="text-center mt-4">
              <a href="?<%= new URLSearchParams({...(currentCategory?{category:currentCategory}:{}), ...(search?{search}:{}), page: currentPage - 1}).toString() %>"
                class="page-btn <%= currentPage <= 1 ? 'disabled' : '' %>">
                <i class="fas fa-chevron-left"></i>
              </a>
              <% for(let p = 1; p <= totalPages; p++) { %>
                <a href="?<%= new URLSearchParams({...(currentCategory?{category:currentCategory}:{}), ...(search?{search}:{}), page: p}).toString() %>"
                  class="page-btn <%= p === currentPage ? 'active' : '' %>">
                  <%= p %>
                </a>
              <% } %>
              <a href="?<%= new URLSearchParams({...(currentCategory?{category:currentCategory}:{}), ...(search?{search}:{}), page: currentPage + 1}).toString() %>"
                class="page-btn <%= currentPage >= totalPages ? 'disabled' : '' %>">
                <i class="fas fa-chevron-right"></i>
              </a>
            </div>
            <% } %>
          <% } %>

        </div>

        <!-- ── CỘT PHẢI: Sidebar ── -->
        <div class="col-lg-4">

          <!-- Danh mục -->
          <div class="cat-filter">
            <div class="cat-filter-title">
              <i class="fas fa-tags me-2" style="color:#E85D28;"></i>Danh mục
            </div>
            <a href="/blog" class="cat-tag <%= !currentCategory ? 'active' : '' %>">
              Tất cả
            </a>
            <% categories.forEach(cat => { %>
              <a href="/blog?category=<%= cat.slug %>"
                class="cat-tag <%= currentCategory === cat.slug ? 'active' : '' %>">
                <%= cat.name %>
                <span class="cat-count"><%= cat.post_count %></span>
              </a>
            <% }) %>
          </div>

          <!-- Bài viết nổi bật -->
          <% if (posts && posts.length > 0) { %>
          <div class="widget">
            <div class="widget-title">
              <i class="fas fa-fire me-2" style="color:#E85D28;"></i>Bài viết nổi bật
            </div>
            <% posts.slice(0, 4).forEach(post => { %>
            <a href="/blog/<%= post.slug %>" class="widget-item">
              <img
                src="/<%= post.thumbnail || '' %>"
                alt="<%= post.title %>"
                onerror="this.src='https://images.unsplash.com/photo-1587300003388-59208cc962cb?w=200&q=60'"
              >
              <div>
                <div class="widget-item-title"><%= post.title %></div>
                <div class="widget-item-meta">
                  <i class="fas fa-eye me-1"></i><%= post.views %> lượt xem
                </div>
              </div>
            </a>
            <% }) %>
          </div>
          <% } %>

          <!-- Banner mua sắm -->
          <div style="background:linear-gradient(135deg,#E85D28,#ff8c5a);border-radius:16px;padding:24px;text-align:center;color:#fff;">
            <div style="font-size:2.5rem;margin-bottom:8px;">🛍️</div>
            <div style="font-family:'Baloo 2',cursive;font-size:1.2rem;font-weight:800;margin-bottom:8px;">
              Khám phá sản phẩm
            </div>
            <p style="font-size:0.85rem;opacity:0.9;margin-bottom:16px;">
              Hàng ngàn phụ kiện cao cấp cho thú cưng của bạn
            </p>
            <a href="/products" style="display:inline-block;background:#fff;color:#E85D28;
              border-radius:10px;padding:10px 20px;font-weight:800;font-size:0.9rem;
              text-decoration:none;transition:all 0.2s;">
              Xem ngay →
            </a>
          </div>

        </div>
      </div>
    </div>
  </main>

  <%- include('partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/api.js"></script>
</body>
</html>
