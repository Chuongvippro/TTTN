<!DOCTYPE html>
<html lang="vi">

<head>
  <meta charset="UTF-8">
  <title>Admin Dashboard</title>
  <link rel="stylesheet" href="/css/admin.css">
</head>

<body>

  <div class="admin-wrapper">

    <div class="sidebar">
      <h2>ADMIN</h2>

      <button class="menu-btn active" onclick="loadSection('dashboard', event)">
        📊 Menu
      </button>
      <button class="menu-btn" onclick="loadSection('products', event)">
        📦 Sản phẩm
      </button>
      <button class="menu-btn" onclick="loadSection('users', event)">
        👤 Người dùng
      </button>
      <button class="menu-btn" onclick="loadSection('categories', event)">
        🏷️ Loại SP
      </button>
      <button class="menu-btn" onclick="loadSection('sales', event)">
        🎉 Khuyến mãi
      </button>
      <button class="menu-btn" onclick="loadSection('orders', event)">
        🛒 Đơn hàng
      </button>
      <button class="menu-btn" onclick="loadSection('blogs', event)">
        📝 Bài viết Blog
      </button>
      <button class="menu-btn" onclick="loadSection('reviews', event)">
        ⭐ Đánh giá
      </button>

      <button class="menu-btn home-btn" onclick="goHome()">
        🏠 Trang chủ
      </button>
      <button class="menu-btn logout" onclick="logout()">
        🚪 Đăng xuất
      </button>
    </div>

    <div class="content">
      <div id="content-box">
        <h2>Bạn đã đến với trang dành cho admin</h2>
        <p>Vui lòng chọn các chức năng bên trái</p>
      </div>
    </div>

  </div>

  <!-- ── Modal Sản phẩm ── -->
  <div id="product-modal" class="modal hidden">
    <div class="modal-content">
      <h2>Thêm sản phẩm</h2>
      <input id="name" placeholder="Tên sản phẩm" />
      <input id="price" placeholder="Giá" />
      <input id="stock" placeholder="Số lượng" />
      <input id="description" placeholder="Mô tả" />
      <select id="category"></select>

      <!-- ✅ THÊM MỚI: Chọn loại thú cưng -->
      <label style="font-weight:600;font-size:0.88rem;margin-bottom:4px;display:block;">🐾 Loại thú cưng</label>
      <select id="pet_type" style="width:100%;padding:10px;margin-bottom:12px;border:1px solid #ddd;border-radius:8px;">
        <option value="all">Tất cả / Không phân loại</option>
        <option value="dog">🐕 Chó</option>
        <option value="cat">🐈 Mèo</option>
        <option value="rabbit">🐇 Thỏ</option>
        <option value="hamster">🐹 Chuột Hamster</option>
        <option value="other">🦎 Khác</option>
      </select>
      <input type="file" id="img" accept="image/*" />
      <img id="preview-img" src="" style="max-width: 100px; display:none;" />
      <div class="form-group" style="margin-bottom: 15px;">
        <label style="font-weight:600; font-size:0.88rem; margin-bottom:4px; display:block;">🎉 Chương trình giảm
          giá</label>
        <select id="product_sale_id" style="width:100%; padding:10px; border:1px solid #ddd; border-radius:8px;">
        </select>
      </div>

      <div id="form-message" class="form-message"></div>
      <button onclick="submitProduct()">Lưu</button>
      <button onclick="closeProductModal()">Hủy</button>
    </div>
  </div>

  <!-- ── Modal User ── -->
  <div id="user-modal" class="modal hidden">
    <div class="modal-content">
      <h2>Thêm người dùng</h2>
      <input id="user_name" placeholder="Tên người dùng" />
      <input id="email" placeholder="Email" />
      <input id="password" placeholder="Mật khẩu" />
      <input id="phone" placeholder="Số điện thoại" />
      <div id="role-group">
        <select id="role">
          <option value="user">User</option>
          <option value="staff">Staff</option>
          <option value="admin">Admin</option>
        </select>
      </div>
      <div id="user-form-message" class="form-message"></div>
      <button onclick="submitUser()">Lưu</button>
      <button onclick="closeUserModal()">Hủy</button>
    </div>
  </div>

  <!-- ── Modal Category ── -->
  <div id="category-modal" class="modal hidden">
    <div class="modal-content">
      <h2 id="cat-modal-title">Thêm danh mục</h2>
      <input id="cat_name" placeholder="Tên danh mục" />
      <textarea id="cat_description" placeholder="Mô tả loại sản phẩm"
        style="width: 100%; margin-bottom: 10px; height: 80px;"></textarea>
      <select id="cat_status" style="width: 100%; margin-bottom: 10px;">
        <option value="active">Hoạt động (active)</option>
        <option value="inactive">Tạm dừng (inactive)</option>
      </select>
      <div id="cat-form-message" class="form-message"></div>
      <button onclick="submitCategory()">Lưu</button>
      <button onclick="closeCategoryModal()">Hủy</button>
    </div>
  </div>

  <!-- ── Modal Chi tiết đơn hàng ── -->
  <div id="order-detail-modal" class="modal hidden">
    <div class="modal-content" style="max-width: 800px; position: relative; padding: 30px;">
      <span onclick="closeOrderDetailModal()"
        style="position: absolute; top: 15px; right: 20px; font-size: 24px; color: #dc3545; cursor: pointer; font-weight: bold;">
        &times;
      </span>
      <h2 style="margin-bottom: 20px; color: #333;">Chi tiết đơn hàng</h2>
      <div id="order-items-list" style="overflow-x: auto;"></div>
      <div
        style="margin-top: 20px; text-align: right; font-weight: 800; font-size: 1.3rem; border-top: 2px solid #eee; padding-top: 15px;">
        Tổng cộng: <span id="modal-total-amount" style="color: #E85D28;">0₫</span>
      </div>
    </div>
  </div>

  <!-- ── Modal Blog ── -->
  <div id="blog-modal" class="modal hidden">
    <div class="modal-content" style="max-width: 700px; max-height: 90vh; overflow-y: auto;">
      <h2 id="blog-modal-title">Thêm bài viết</h2>
      <label style="font-weight:600;font-size:0.9rem;">Tiêu đề *</label>
      <input id="blog_title" placeholder="Tiêu đề bài viết" style="margin-bottom:10px;" />

      <label style="font-weight:600;font-size:0.9rem;">Tóm tắt</label>
      <textarea id="blog_summary" placeholder="Mô tả ngắn về bài viết..."
        style="width:100%;height:70px;margin-bottom:10px;border:1px solid #ddd;border-radius:8px;padding:8px;"></textarea>
      <label style="font-weight:600;font-size:0.9rem;">Ảnh thumbnail</label>
      <input type="file" id="blog_img" accept="image/*" style="margin-bottom:6px;" />
      <img id="blog-img-preview" src="" style="max-width:120px;display:none;margin-bottom:10px;border-radius:6px;" />
      <label style="font-weight:600;font-size:0.9rem;">Nội dung * (hỗ trợ HTML)</label>
      <textarea id="blog_content"
        placeholder="Nội dung bài viết (có thể dùng thẻ HTML như &lt;h3&gt;, &lt;p&gt;, &lt;ul&gt;...)"
        style="width:100%;height:200px;margin-bottom:10px;border:1px solid #ddd;border-radius:8px;padding:8px;font-family:monospace;font-size:0.85rem;"></textarea>

      <label style="font-weight:600;font-size:0.9rem;">Danh mục blog</label>
      <select id="blog_category" style="width:100%;margin-bottom:10px;">
        <option value="">-- Chọn danh mục --</option>
      </select>

      <label style="font-weight:600;font-size:0.9rem;">Trạng thái</label>
      <select id="blog_status" style="width:100%;margin-bottom:10px;">
        <option value="published">Hiển thị (published)</option>
        <option value="draft">Nháp (draft)</option>
      </select>

      <div id="blog-form-message" class="form-message"></div>
      <button onclick="submitBlog()">💾 Lưu bài viết</button>
      <button onclick="closeBlogModal()">Hủy</button>
    </div>
  </div>

  <div id="sale-modal" class="modal hidden">
    <div class="modal-content">
      <h2 id="sale-modal-title">Thêm chương trình Sale</h2>

      <label style="font-weight:600;font-size:0.9rem;">Mã Khuyến Mãi (Có thể để trống nếu tự động)</label>
      <input id="sale_code" placeholder="VD: NOEL2026, TET..." style="margin-bottom:10px;" />

      <label style="font-weight:600;font-size:0.9rem;">% Giảm giá *</label>
      <input type="number" id="sale_percent_input" placeholder="VD: 15" min="1" max="100" style="margin-bottom:10px;" />

      <label style="font-weight:600;font-size:0.9rem;">Thời gian bắt đầu *</label>
      <input type="datetime-local" id="sale_start" style="width:100%;margin-bottom:10px;" />

      <label style="font-weight:600;font-size:0.9rem;">Thời gian kết thúc *</label>
      <input type="datetime-local" id="sale_end" style="width:100%;margin-bottom:10px;" />

      <label style="font-weight:600;font-size:0.9rem;">Mô tả chương trình</label>
      <textarea id="sale_description" placeholder="Ghi chú chiến dịch..."
        style="width:100%;height:60px;margin-bottom:10px;"></textarea>
      <label style="font-weight:600;font-size:0.9rem;">Trạng thái</label>
      <select id="sale_status"
        style="width:100%;margin-bottom:15px;padding:8px;border-radius:4px;border:1px solid #ddd;">
        <option value="active">Đang bật (Active)</option>
        <option value="inactive">Tạm ẩn / Tắt (Inactive)</option>
      </select>
      <select id="sale_apply_category"
        style="width:100%;margin-bottom:15px;padding:8px;border-radius:4px;border:1px solid #ddd;">
        <option value="">-- Không áp dụng theo loại --</option>
      </select>
      <div style="margin-bottom: 15px; background: #e3f2fd; padding: 10px; border-radius: 6px;">
        <label
          style="display: flex; align-items: center; cursor: pointer; font-weight: 600; font-size: 0.9rem; color: #0d47a1; margin: 0;">
          <input type="checkbox" id="sale_apply_all"
            style="margin-right: 8px; width: 18px; height: 18px; cursor: pointer;">
          ✅ Áp dụng mã giảm giá này cho TẤT CẢ sản phẩm
        </label>
      </div>
      <div id="sale-form-message" class="form-message"></div>
      <button onclick="submitSale()">💾 Lưu Khuyến Mãi</button>
      <button onclick="closeSaleModal()">Hủy</button>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script src="/js/api.js"></script>
  <script src="/js/admin.js"></script>
  <script src="/js/admin.api.js"></script>

</body>

</html>