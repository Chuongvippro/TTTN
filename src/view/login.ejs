<!DOCTYPE html>
<html lang="vi">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Đăng nhập — Pawmie Pet Shop</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
  <link
    href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@400;700;800&family=Nunito:wght@400;600;700;800&display=swap"
    rel="stylesheet">

  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      min-height: 100vh;
      background: linear-gradient(135deg, #fff8f5 0%, #ffeee6 50%, #fff3f0 100%);
      font-family: 'Nunito', sans-serif;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
    }

    .login-wrapper {
      width: 100%;
      max-width: 440px;
    }

    /* ── Logo / Header ── */
    .login-header {
      text-align: center;
      margin-bottom: 32px;
    }

    .login-logo {
      font-size: 3rem;
      margin-bottom: 8px;
      display: block;
    }

    .login-brand {
      font-family: 'Baloo 2', cursive;
      font-size: 2rem;
      font-weight: 800;
      color: #E85D28;
      line-height: 1;
    }

    .login-tagline {
      color: #888;
      font-size: 0.92rem;
      font-weight: 600;
      margin-top: 4px;
    }

    /* ── Card ── */
    .login-card {
      background: #fff;
      border-radius: 24px;
      padding: 36px 32px;
      box-shadow: 0 12px 40px rgba(232, 93, 40, 0.1);
      border: 1.5px solid #fde8e0;
    }

    .login-title {
      font-family: 'Baloo 2', cursive;
      font-size: 1.5rem;
      font-weight: 700;
      color: #222;
      margin-bottom: 24px;
      text-align: center;
    }

    /* ── Form ── */
    .form-group {
      margin-bottom: 18px;
    }

    .form-label {
      font-weight: 700;
      font-size: 0.88rem;
      color: #444;
      margin-bottom: 7px;
      display: block;
    }

    .input-wrap {
      position: relative;
    }

    .input-wrap .input-icon {
      position: absolute;
      left: 14px;
      top: 50%;
      transform: translateY(-50%);
      color: #bbb;
      font-size: 0.95rem;
      pointer-events: none;
    }

    .form-input {
      width: 100%;
      padding: 12px 14px 12px 40px;
      border: 1.5px solid #e8e8e8;
      border-radius: 12px;
      font-family: 'Nunito', sans-serif;
      font-size: 0.95rem;
      color: #333;
      transition: border-color 0.2s, box-shadow 0.2s;
      outline: none;
      background: #fafafa;
    }

    .form-input:focus {
      border-color: #E85D28;
      box-shadow: 0 0 0 3px rgba(232, 93, 40, 0.1);
      background: #fff;
    }

    /* Toggle show/hide password */
    .toggle-pw {
      position: absolute;
      right: 14px;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      color: #aaa;
      cursor: pointer;
      font-size: 0.9rem;
      padding: 0;
      transition: color 0.2s;
    }

    .toggle-pw:hover {
      color: #E85D28;
    }

    /* ── Nút đăng nhập ── */
    .btn-login {
      width: 100%;
      padding: 13px;
      background: #E85D28;
      color: #fff;
      border: none;
      border-radius: 12px;
      font-family: 'Nunito', sans-serif;
      font-size: 1.05rem;
      font-weight: 800;
      cursor: pointer;
      margin-top: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      transition: all 0.25s;
    }

    .btn-login:hover:not(:disabled) {
      background: #d65120;
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(232, 93, 40, 0.3);
    }

    .btn-login:disabled {
      opacity: 0.65;
      cursor: not-allowed;
    }

    /* ── Message ── */
    .msg-box {
      display: none;
      padding: 11px 16px;
      border-radius: 10px;
      font-size: 0.9rem;
      font-weight: 700;
      margin-bottom: 18px;
      text-align: center;
    }

    .msg-box.success {
      background: #d1fae5;
      color: #065f46;
      border: 1.5px solid #a7f3d0;
    }

    .msg-box.error {
      background: #fee2e2;
      color: #991b1b;
      border: 1.5px solid #fecaca;
    }

    /* ── Nút khôi phục tài khoản ── */
    .btn-restore {
      display: none;
      width: 100%;
      padding: 11px;
      background: #fff;
      color: #E85D28;
      border: 2px solid #E85D28;
      border-radius: 12px;
      font-family: 'Nunito', sans-serif;
      font-size: 0.95rem;
      font-weight: 700;
      cursor: pointer;
      margin-top: 12px;
      transition: all 0.2s;
    }

    .btn-restore:hover {
      background: #fff3ee;
    }

    /* ── Divider ── */
    .divider {
      display: flex;
      align-items: center;
      gap: 12px;
      margin: 22px 0;
    }

    .divider::before,
    .divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: #f0f0f0;
    }

    .divider span {
      font-size: 0.82rem;
      color: #aaa;
      font-weight: 600;
      white-space: nowrap;
    }

    /* ── Link đăng ký ── */
    .signup-link {
      text-align: center;
      font-size: 0.92rem;
      color: #666;
      font-weight: 600;
    }

    .signup-link a {
      color: #E85D28;
      font-weight: 800;
      text-decoration: none;
    }

    .signup-link a:hover {
      text-decoration: underline;
    }

    /* ── Back home ── */
    .back-home {
      text-align: center;
      margin-top: 20px;
    }

    .back-home a {
      font-size: 0.88rem;
      color: #888;
      font-weight: 600;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }

    .back-home a:hover {
      color: #E85D28;
    }
  </style>
</head>

<body>

  <div class="login-wrapper">

    <!-- Header -->
    <div class="login-header">
      <span class="login-logo">🐾</span>
      <div class="login-brand">Pawmie</div>
      <div class="login-tagline">Yêu thương thú cưng từng khoảnh khắc</div>
    </div>

    <!-- Card -->
    <div class="login-card">
      <div class="login-title">Chào mừng trở lại!</div>

      <!-- Message box -->
      <div class="msg-box" id="msgBox"></div>

      <!-- Form -->
      <div class="form-group">
        <label class="form-label">Email</label>
        <div class="input-wrap">
          <i class="fas fa-envelope input-icon"></i>
          <input type="email" class="form-input" id="email" placeholder="example@email.com" autocomplete="email">
        </div>
      </div>

      <div class="form-group">
        <label class="form-label">Mật khẩu</label>
        <div class="input-wrap">
          <i class="fas fa-lock input-icon"></i>
          <input type="password" class="form-input" id="password" placeholder="Nhập mật khẩu"
            autocomplete="current-password">
          <button class="toggle-pw" type="button" onclick="togglePassword()" id="togglePwBtn">
            <i class="fas fa-eye" id="pwIcon"></i>
          </button>
        </div>
      </div>

      <button class="btn-login" id="loginBtn" onclick="handleLogin()">
        <i class="fas fa-sign-in-alt"></i> Đăng nhập
      </button>

      <button class="btn-restore" id="restoreBtn">
        <i class="fas fa-undo me-2"></i> Khôi phục tài khoản
      </button>

      <div class="divider"><span>hoặc</span></div>

      <div class="signup-link">
        Chưa có tài khoản? <a href="/user/signIn">Đăng ký ngay</a>
      </div>
    </div>

    <div class="back-home">
      <a href="/"><i class="fas fa-arrow-left"></i> Về trang chủ</a>
    </div>

  </div>

  <script>
    // ── Toggle show/hide password ──
    function togglePassword() {
      const input = document.getElementById('password');
      const icon = document.getElementById('pwIcon');
      const isHide = input.type === 'password';
      input.type = isHide ? 'text' : 'password';
      icon.className = isHide ? 'fas fa-eye-slash' : 'fas fa-eye';
    }

    // ── Hiển thị message ──
    function showMsg(text, type) {
      const box = document.getElementById('msgBox');
      box.textContent = text;
      box.className = `msg-box ${type}`;
      box.style.display = 'block';
    }

    // ── Xử lý đăng nhập ──
    async function handleLogin() {
      const email = document.getElementById('email').value.trim();
      const password = document.getElementById('password').value;
      const btn = document.getElementById('loginBtn');

      if (!email || !password) {
        showMsg('Vui lòng nhập email và mật khẩu!', 'error');
        return;
      }

      btn.disabled = true;
      btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang đăng nhập...';

      try {
        const res = await fetch('/user/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, password }),
        });

        const data = await res.json();

        // Tài khoản bị xóa
        if (data.status === 'deleted') {
          showMsg(data.message, 'error');
          document.getElementById('restoreBtn').style.display = 'block';
          document.getElementById('restoreBtn').dataset.email = email;
          document.getElementById('restoreBtn').dataset.password = password;
          return;
        }

        if (!res.ok) throw new Error(data.message || 'Đăng nhập thất bại!');

        // Lưu token
        localStorage.setItem('accessToken', data.data.accessToken);
        localStorage.setItem('refreshToken', data.data.refreshToken);
        localStorage.setItem('user', JSON.stringify(data.data.user));

        await syncCartAfterLogin();

        showMsg('Đăng nhập thành công! Đang chuyển hướng...', 'success');

        setTimeout(() => { window.location.href = '/'; }, 1000);

      } catch (err) {
        showMsg(err.message, 'error');
      } finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-sign-in-alt"></i> Đăng nhập';
      }
    }

    // ── Enter để submit ──
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') handleLogin();
    });

    // ── Khôi phục tài khoản ──
    document.getElementById('restoreBtn').addEventListener('click', async () => {
      const btn = document.getElementById('restoreBtn');
      const email = btn.dataset.email;
      const password = btn.dataset.password;

      btn.disabled = true;
      btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i> Đang khôi phục...';

      try {
        const res = await fetch('/auth/restore', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, password }),
        });
        const data = await res.json();

        if (res.ok) {
          showMsg('Khôi phục thành công! Vui lòng đăng nhập lại.', 'success');
          btn.style.display = 'none';
        } else {
          showMsg(data.message, 'error');
        }
      } catch {
        showMsg('Có lỗi xảy ra, thử lại nhé!', 'error');
      } finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-undo me-2"></i> Khôi phục tài khoản';
      }
    });
  </script>
  <script src="/js/home.js"></script>
  <script src="/js/api.js"></script>
</body>

</html>