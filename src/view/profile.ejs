<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Tài khoản — Pawmie Pet Shop</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
    <link
        href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@400;500;600;700;800&family=Nunito:wght@400;500;600;700;800;900&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="/css/profile.css">
    <link rel="stylesheet" href="/css/home.css">
</head>

<body>

    <%- include('partials/navbar') %>

        <main>
            <div class="card">
                <div class="header"></div>

                <img class="avatar" src="<%= user?.avatar || 'https://i.pravatar.cc/150' %>" />

                <div class="content">
                    <h2>
                        <span id="username">
                            <%= user?.username || user?.user_name || 'Đang tải...' %>
                        </span>
                    </h2>
                    <div class="role" id="role">
                        <%= user?.role || 'User' %>
                    </div>

                    <div class="info" id="staticInfo">
                        <div class="row">
                            <span class="label">Email</span>
                            <span id="email">
                                <%= user?.email || "trống" %>
                            </span>
                        </div>
                        <div class="row">
                            <span class="label">SĐT</span>
                            <span id="phone">
                                <%= user?.phone || "trống" %>
                            </span>
                        </div>
                        <div class="row">
                            <span class="label">Địa chỉ</span>
                            <span id="address">
                                <%= user?.address || "trống" %>
                            </span>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4 justify-content-center" id="actionButtons">
                        <button class="btn btn-primary" onclick="updateInforUser()">
                            <i class="fas fa-user-edit me-1"></i> Cập nhật thông tin
                        </button>

                        <button class="btn btn-info text-white" onclick="showMyOrders()"
                            style="background-color: #E85D28; border: none;">
                            <i class="fas fa-shopping-bag me-1"></i> Đơn hàng của tôi
                        </button>

                        <button class="btn btn-secondary" onclick="location.href='/'">
                            <i class="fas fa-home me-1"></i> Về trang chủ
                        </button>
                    </div>

                    <div id="editForm" style="display: none; margin-top: 20px; text-align: left; width: 100%;">
                        <hr>
                        <h5 class="text-center mb-3" style="font-weight: 700; color: #E85D28;">Chỉnh sửa thông tin</h5>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Tên hiển thị</label>
                            <input type="text" id="edit-username" class="form-control"
                                value="<%= user?.username || user?.user_name || '' %>">
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Số điện thoại</label>
                            <input type="text" id="edit-phone" class="form-control" value="<%= user?.phone || '' %>">
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Địa chỉ</label>
                            <input type="text" id="edit-address" class="form-control"
                                value="<%= user?.address || '' %>">
                        </div>
                        <div class="d-flex gap-2 justify-content-center mt-3">
                            <button class="btn btn-success" onclick="saveUserInfo()">Lưu thay đổi</button>
                            <button class="btn btn-secondary" onclick="cancelEdit()">Hủy</button>
                        </div>
                    </div>

                    <div id="myOrdersSection" style="display: none; margin-top: 25px; width: 100%;">
                        <hr>
                        <h5 class="text-center mb-4"
                            style="font-weight: 700; color: #333; font-family: 'Baloo 2', cursive;">
                            🐾 Lịch sử mua hàng của bạn
                        </h5>
                        <div id="ordersList">
                        </div>
                    </div>
                </div>
            </div>
        </main>

        <%- include('partials/footer') %>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
            <script src="/js/profile.js"></script>

</body>

</html>