<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Giỏ hàng của bạn — Pawmie Pet Shop</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
    <link
        href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@400;500;600;700;800&family=Nunito:wght@400;500;600;700;800;900&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="/css/home.css">

    <style>
        main {
            background-color: #f9fafb;
            min-height: 80vh;
            padding: 40px 0;
            font-family: 'Nunito', sans-serif;
        }

        .cart-title {
            font-family: 'Baloo 2', cursive;
            font-weight: 800;
            color: #333;
            margin-bottom: 30px;
            font-size: 2rem;
        }

        /* --- CỘT TRÁI: DANH SÁCH SẢN PHẨM --- */
        .cart-item-card {
            background: #fff;
            border-radius: 16px;
            padding: 20px;
            margin-bottom: 20px;
            border: 1px solid #f1f1f1;
            display: flex;
            align-items: center;
            gap: 20px;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .cart-item-card:hover {
            box-shadow: 0 8px 24px rgba(232, 93, 40, 0.08);
            transform: translateY(-2px);
        }

        .cart-item-img {
            width: 110px;
            height: 110px;
            object-fit: cover;
            border-radius: 12px;
            border: 1px solid #eee;
            flex-shrink: 0;
        }

        .cart-item-info {
            flex-grow: 1;
        }

        .cart-item-category {
            font-size: 0.85rem;
            color: #888;
            text-transform: uppercase;
            font-weight: 700;
            letter-spacing: 0.5px;
            margin-bottom: 4px;
        }

        .cart-item-name {
            font-size: 1.15rem;
            font-weight: 700;
            color: #222;
            margin-bottom: 8px;
            display: block;
            text-decoration: none;
        }

        .cart-item-name:hover {
            color: #E85D28;
        }

        .cart-item-price {
            font-size: 1.1rem;
            font-weight: 800;
            color: #E85D28;
        }

        /* Group tăng/giảm số lượng */
        .qty-group {
            display: flex;
            align-items: center;
            background: #f8f9fa;
            border-radius: 99px;
            padding: 4px;
            border: 1px solid #eee;
        }

        .qty-btn {
            background: #fff;
            border: none;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            color: #555;
            cursor: pointer;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.05);
            transition: all 0.2s;
        }

        .qty-btn:hover {
            background: #E85D28;
            color: #fff;
        }

        .qty-input {
            width: 40px;
            border: none;
            background: transparent;
            text-align: center;
            font-weight: 700;
            font-size: 1rem;
            color: #333;
            outline: none;
        }

        /* Nút xóa */
        .btn-remove {
            background: rgba(255, 77, 77, 0.1);
            color: #ff4d4d;
            border: none;
            width: 40px;
            height: 40px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.2s;
            flex-shrink: 0;
        }

        .btn-remove:hover {
            background: #ff4d4d;
            color: #fff;
        }

        /* --- CỘT PHẢI: TÓM TẮT ĐƠN HÀNG --- */
        .summary-box {
            background: #fff;
            border-radius: 20px;
            padding: 24px;
            border: 1px solid #f1f1f1;
            position: sticky;
            top: 100px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
        }

        .summary-title {
            font-family: 'Baloo 2', cursive;
            font-size: 1.4rem;
            font-weight: 700;
            color: #333;
            border-bottom: 2px dashed #eee;
            padding-bottom: 16px;
            margin-bottom: 20px;
        }

        .summary-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 16px;
            font-size: 1rem;
            color: #555;
            font-weight: 600;
        }

        .summary-total {
            display: flex;
            justify-content: space-between;
            margin-top: 20px;
            padding-top: 20px;
            border-top: 2px dashed #eee;
            font-size: 1.3rem;
            font-weight: 800;
            color: #222;
        }

        .total-price {
            color: #E85D28;
            font-size: 1.5rem;
        }

        .btn-checkout {
            width: 100%;
            background: #E85D28;
            color: #fff;
            border: none;
            padding: 14px;
            border-radius: 12px;
            font-size: 1.1rem;
            font-weight: 700;
            margin-top: 24px;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .btn-checkout:hover {
            background: #d65120;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(232, 93, 40, 0.3);
        }

        /* Nút lưu số lượng (mặc định ẩn) */
        .btn-confirm-qty {
            background: #28a745;
            color: #fff;
            border: none;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: none;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            margin-left: 10px;
            box-shadow: 0 2px 5px rgba(40, 167, 69, 0.3);
            transition: all 0.2s;
            flex-shrink: 0;
        }

        .btn-confirm-qty:hover {
            background: #218838;
            transform: scale(1.1);
        }
    </style>
</head>

<body>

    <%- include('partials/navbar') %>

        <main>
            <div class="container">
                <h1 class="cart-title">
                    <i class="fas fa-shopping-bag me-2" style="color: #E85D28;"></i> Giỏ hàng của bạn
                </h1>

                <div class="row g-4">

                    <div class="col-lg-8" id="cartItemsContainer">
                        <div class="text-center py-5">
                            <i class="fas fa-spinner fa-spin fa-2x" style="color: #E85D28;"></i>
                            <p class="mt-3" style="color: #888;">Đang tải giỏ hàng...</p>
                        </div>
                    </div>

                    <div class="col-lg-4">
                        <div class="summary-box">
                            <div class="summary-title">Tóm tắt đơn hàng</div>

                            <div class="summary-row">
                                <span>Tạm tính (0 sản phẩm)</span>
                                <span>0₫</span>
                            </div>

                            <div class="summary-row">
                                <span>Phí vận chuyển</span>
                                <span style="color: #28a745;">Miễn phí</span>
                            </div>

                            <div class="summary-total">
                                <span>Tổng cộng</span>
                                <span class="total-price">0₫</span>
                            </div>

                            <p style="font-size: 0.85rem; color: #888; text-align: right; margin-top: 5px;">
                                (Đã bao gồm VAT nếu có)
                            </p>

                            <button class="btn-checkout" onclick="location.href='/order/checkout'">
                                Thanh toán ngay <i class="fas fa-arrow-right"></i>
                            </button>
                        </div>
                    </div>

                </div>
            </div>
        </main>

        <%- include('partials/footer') %>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
            <script src="/js/api.js"></script>
            <script src="/js/user.api.js"></script>

</body>

</html>